{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "*.{json,js,css,png,jpg,svg,ico}"
    ]
  },
  "routes": [
    {
      "route": "/api/trips",
      "methods": [
        "get"
      ],
      "allowedRoles": [
        "edtior"
      ]
    },
    {
      "route": "/api/trips",
      "methods": [
        "POST",
        "PUT"
      ],
      "allowedRoles": [
        "editor"
      ]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 401
    }
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}